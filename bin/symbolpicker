#!/usr/bin/env fish

# A Rofi/Wofi script to pick a Unicode symbol and type it.
# Dependencies:
# - rofi (for X11) or wofi (for Wayland)
# - xdotool (for X11) or wtype (for Wayland)

# --- Symbol List ---
# Format: "Symbol\tHexCode\tDecimalCode\tDescription"
set symbols "╬▒\t03B1\t945\tAlpha
╬▓\t03B2\t946\tBeta
╬│\t03B3\t947\tGamma
╬┤\t03B4\t948\tDelta
