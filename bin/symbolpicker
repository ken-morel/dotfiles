Ôčę	27E9	10217	Mathematical Right Angle Bracket
╬Ş	03B8	952\tTheta
╬Â	03B6	950\tZeta
╬Ě	03B7	951\tEta
╬║	03BA	954\tKappa
╬Ż	03BD	957\tNu
╬ż	03BE	958\tXi
¤ü	03C1	961\tRho
¤ä	03C4	964\tTau
¤ů	03C5	965\tUpsilon
¤ć	03C6	966\tPhi
¤ç	03C7	967\tChi
¤ł	03C8	968\tPsi
¤ë	03C9	969\tOmega
╬ś	0398	920\tTheta (Uppercase)
╬Ž	03A6	934\tPhi (Uppercase)
╬Ę	03A8	936\tPsi (Uppercase)
╬ę	03A9	937\tOmega (Uppercase)
ÔäĽ	2115	8469	Natural Numbers
ÔäĄ	2124	8484	Integers
ÔäÜ	211A	8474	Rational Numbers
ÔäŁ	211D	8477	Real Numbers
Ôäé	2102	8450	Complex Numbers
"

# --- Picker Logic ---
# Detect if we are on Wayland or X11 and choose the picker
set picker_cmd ""
set picker_args

if test "$XDG_SESSION_TYPE" = "wayland"
    if command -v wofi > /dev/null
        set picker_cmd wofi
        set picker_args --dmenu -i -p 'Select Symbol'
    else if command -v rofi > /dev/null
        # Fallback to rofi if wofi is not found, even on Wayland
        set picker_cmd rofi
        set picker_args -dmenu -i -p 'Select Symbol'
    end
else
    if command -v rofi > /dev/null
        set picker_cmd rofi
        set picker_args -dmenu -i -p 'Select Symbol'
    end
end

if test -z "$picker_cmd"
    echo "Error: Rofi or Wofi not found." >&2
    exit 1
end

# --- Selection and Typing ---
# Pipe the list into the picker and capture the selection
set selection (echo -e $symbols | $picker_cmd $picker_args)

# If the user made a selection (didn't press Escape)
if test -n "$selection"
    # Extract just the symbol, which is the first field
    set symbol (echo "$selection" | string split --max 1 \t)[1]

    # Use the correct tool to type the character
    if test "$XDG_SESSION_TYPE" = "wayland"
        if command -v wtype > /dev/null
            wtype "$symbol"
        else
            echo "Error: 'wtype' is not installed. Please install it for Wayland support." >&2
            exit 1
        end
    else
        if command -v xdotool > /dev/null
            # Use --clearmodifiers to prevent issues with held-down keys
            xdotool type --clearmodifiers "$symbol"
        else
            echo "Error: 'xdotool' is not installed. Please install it for X11 support." >&2
            exit 1
        end
    end
end