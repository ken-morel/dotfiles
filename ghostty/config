font-family = Iosevka NFM
# FiraCode Nerd Font Mono
font-family-italic = Iosevka Nerd Font Mono
font-family-bold-italic = Iosevka Nerd Font Mono

window-padding-x = 0
window-padding-y = 0

# fullscreen = true

alpha-blending=linear
# adjust-cell-height=-1%
font-size=10
background-opacity=0.5
# background=#f00000

freetype-load-flags = false
minimum-contrast=0
gtk-tabs-location=bottom
adjust-icon-height=50%
cursor-click-to-move=false
background-blur=true
link-previews=true
window-inherit-working-directory=true
window-save-state=always
window-new-tab-position=current
focus-follows-mouse=false
keybind = ctrl+shift+a=toggle_quick_terminal
# shell-integration=fish
shell-integration-features=no-cursor,sudo,title,ssh-env,ssh-terminfo
# initial-command=nu

command-palette-entry = title:Reset Font Style, action:csi:0m
command-palette-entry = title:Crash on Main Thread,description:Causes a crash on the main (UI) thread.,action:crash:main
command-palette-entry = title:Focus Split: Right,description:"Focus the split to the right, if it exists.",action:goto_split:right
command-palette-entry = title:"Ghostty",description:"Add a little Ghostty to your terminal.",action:"text:\xf0\x9f\x91\xbb"


bell-features=system,audio,attention,title,border
bell-audio-path=bell.wav

# remove for fast startup
linux-cgroup=always

# top bar maybe
gtk-titlebar=true
# command=tmux
#
desktop-notifications=true
term=xterm-ghostty
cursor-style=bar
#
gtk-single-instance = true



keybind = ctrl+shift+h=goto_split:left
keybind = ctrl+shift+j=goto_split:bottom
keybind = ctrl+shift+k=goto_split:top
keybind = ctrl+shift+l=goto_split:right

mouse-scroll-multiplier = 0.1

# theme = Everforest Dark Hard

# Japanese font fallback
font-codepoint-map = U+3000-U+303F=Noto Sans CJK JP
font-codepoint-map = U+3040-U+309F=Noto Sans CJK JP
font-codepoint-map = U+30A0-U+30FF=Noto Sans CJK JP
font-codepoint-map = U+4E00-U+9FFF=Noto Sans CJK JP

selection-clear-on-typing = false
